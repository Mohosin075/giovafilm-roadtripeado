            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKthRBRreYkwxDHpt1kkojtL4bUV9vyHQnLVxK2FhM4eai_EOjqBjUqZItWSgY7RSc8-US2qJRztKgD2WDeTxf6bDGc1fPKeKz2JiREple49zO6nuEkaYTZx8sBsXrbOwERJYn0qlGtM2WlwnPWGzMU-Nl5BhlhGtWICCC2j9ye7IeyCvWT70ZgXMkg0GlnR3hzcVDHWOBNPODxW-yyMCEuFqlDytGIL1Jh64GC-8K5ESstZDLobWyiZyWAsvQ?authuser=3&fife=s16383 https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKuQkjxJKiVlANjChPZhNmUFo-BXd7YTD6pQZAv98ZJDu_LXevZdjS_rxWxGL_pN-9811PtZqha31dSnYiQXAOuTgrGzvwJU3-pO1rfLL7hqP8TGmNKGvPDq50yHEhwmoJjOWXUtWChFeynx-k_ugBYXlopvR-f2qj0D6iRn1FpVn7nLVbFWqagEwvDfN00orDAiEqy-o9NGqCtwXZvUeNj7FmXJOVj_nM-UGOs6zCyVFY-6bZy9sqs8jp0VOQ?authuser=3&fife=s16383]]></value>
