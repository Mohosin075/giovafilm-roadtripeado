            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKu_Hwnk11eK_TLnHA8698CHfzouHvluBMkPUPPyorA9k__80MmbVw1ssMyJ2qgF_-2aIkY4ROqvBYLuChNKNk2bSfTwtC6lYJnX_meh6eF3EKa1P7bWHuP7em1x4NP3Vx1GPc2ORsY0zXVtbMhZtX7sCSP18BdtmPJDqzRbswoFRUKYeXMmj3dgUK-dgS2lFALw6UXCECiNDP0fruueUaGAfehCjAXam3HKftLdhgTuXiglF9PGjuYweFEouA?authuser=3&fife=s16383 https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKtJchFj_3PMJz5WB-pt5ZCCZnUPXZvPc2XUvuqa4dL-VMpUlWvZrnHEfuKDPd2bTgIISmF3D00xtnjd4APr3EGsM21twzyAnh8KQI3IuK5tdAhhE13Jxh8dlx9g0gJk25bSmIQjuWrosR0Oemo8_MkD5lbkBvbjDSFBWa7uEO0OTU1gBHN03fdMqfgeUMBqbdb3_njaXa4T0jWuE4nFYQG7nCzDChXaV76aghBenZ2vrmhF0gdxPjGDj5Wgkg?authuser=3&fife=s16383]]></value>
