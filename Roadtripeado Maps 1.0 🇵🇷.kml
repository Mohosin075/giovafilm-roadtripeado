            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKua1Xosb3Gb9mjGWOuMUorAyw9uxf3BDu2vxCYl0YSwPaNZlm4QqNm6F796t3MRCC-AlGQV11QhKOhTbiesc9WCyEknr8LhCWAmGOA1AhIJq2Gqea5-DKYDtZ7peJsfyOcsiU354QothMiIrhE7rWyHZC89nBpdJiOEq8lvjIEvFUPAv5y5rDDbrlcjWuZY1TpmfP4L0idmNLdeH7_vdG-MWVD5SCDc-65W49M2NYiW31D154y9jeDqmqYO2g?authuser=3&fife=s16383]]></value>
