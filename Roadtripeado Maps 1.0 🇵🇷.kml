            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKsHG3L2WdZIzpkrn_FmwbFFJ4CQtzkugw9R5wFnZ0y3odLZ2Sb-SLf1pA5J1iqRAzP7xVC6eBiXe172TI6I0i9MXWnc7sgdsKNNiO5zzzL2q4XcTV7fY3C2nEiyi0mylp7gD9Lx-K6SovY1nlW1XJMTU7bRztbDqFG4j80CTazVH1m1hy1TGlPMiV0HZqkWAH5EP42nFA9aQjESm9c9dzzPaKOuAhI6i21gvdLwkYPOnd5_6N7EEYLM8p1eiQ?authuser=3&fife=s16383 https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKvTV1noEzLx_x8vsqHA6LtrZZgjOZjPo5TtBORq8G-jn4jmJB-IIc6DRm-Ms5UbEhsWaIKK8_BBe_lQttsL4IUkNSmFZGL1QN1qxhShVAMfWRI1x5RpbpdazcwKRcsCrmO4YHYfGtSsxBjNq1E6qyMEbEKNaqjgVWVVr6PWXXMtMYdQsxKgEC26R3fDv6hW8VCiMTA9FMgp_LL0VVxktTYi8uFDEBooy0lMdjS2VJbx5XdmtT7uvaUQ0LSPnQ?authuser=3&fife=s16383]]></value>
