            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKti7-El-e8tI7UyI5Dr5ur2KbUN5AU6fjy8NdRxeebONqZjXvKdiVOX-8yo-BMbCuj2Dhgj0FMvJEqbWkYzELhhNKewTVhTtHSIVUX2SheMQQfrtg1aEXHGCXY7wrS4B2jBebJ8MtpiYw0ELr6K12jH6jxL0h4mdM4G0CL0o-fGInVavnMQLjso2w4aBlpFoQY1WWTIpRv4C6HEoTY8yuS7l6rr9fEP05tur835Ltab5wmKn2dwcYjVPbfVqw?authuser=3&fife=s16383]]></value>
