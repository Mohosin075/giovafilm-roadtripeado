            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3ADbDBKuUU5NBysNP5pWdUR7lJT2PyS26UhabUkWLqmf4LvzI6WJVj7xEaRGFguul2K65Wd3yDwdMyCDQgteCrU28VCAgyuw5QBs5cn99nCnApDrDao64rihnuExJXpgRpN7eRPt6zla0uNWlBQ4UKmo_1GImnFGgKVEmaG9wJP-3hra8FJ7qQCl1s7ftfJtPA-ux--ul8Rw4VCoFwRg2RtBi6fGX8-9hfuH5CAKNDKqhgBCn4nCkH0uplTjFROPK8w?authuser=3&fife=s16383]]></value>
